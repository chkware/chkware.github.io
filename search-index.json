grade chk Copy Otherwise, if pip was used to install then same process given above should work for upgrade as well.","s":"Upgrade","u":"/setup","h":"#upgrade","p":1},{"i":7,"t":"For now this tool is developed and tested on macOS only. We are working hard to make it available on Linux platform.","s":"Platform support","u":"/setup","h":"#platform-support","p":1},{"i":9,"t":"Current stability for this tool is Pre - Alpha","s":"Stability","u":"/setup","h":"#stability","p":1}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/3",[0,0.384,1,0.667,2,1.772,3,0.614,4,0.667,5,0.667,6,0.667,7,0.667,8,0.614,9,1.066,10,1.331,11,0.667,12,0.957,13,0.667,14,0.667,15,0.667,16,0.667,17,1.066,18,0.667,19,0.667,20,0.667,21,0.667,22,0.667,23,1.176,24,0.667,25,1.071,26,0.766,27,0.766,28,0.667,29,1.201,30,1.331,31,0.667,32,0.667,33,1.331,34,1.331,35,1.331,36,1.52,37,0.614,38,0.667,39,0.667,40,1.066,41,0.667,42,0.667,43,0.667,44,0.667,45,0.667,46,1.331,47,0.667,48,1.066,49,0.667,50,1.066,51,0.667,52,0.667,53,0.667]],["t/5",[3,0.821,8,0.821,12,1.067,23,1.067,25,0.821,26,0.821,27,0.821,29,0.821,37,1.186,54,1.854,55,1.426,56,1.426,57,1.426,58,1.426,59,1.426,60,1.426,61,1.426,62,0.821,63,1.426]],["t/7",[62,0.98,64,1.703,65,0.98,66,1.703,67,1.703,68,1.703,69,1.703,70,1.703,71,1.703,72,1.703,73,1.703]],["t/9",[0,1.077,65,1.077,74,1.87,75,1.87,76,1.87]]],"invertedIndex":[["",{"_index":25,"t":{"3":{"position":[[310,1],[506,1],[538,1],[732,1],[756,1],[812,1],[861,1]]},"5":{"position":[[90,1]]}}}],["1",{"_index":11,"t":{"3":{"position":[[155,2]]}}}],["2",{"_index":28,"t":{"3":{"position":[[341,2]]}}}],["3",{"_index":38,"t":{"3":{"position":[[595,2]]}}}],["3.8",{"_index":4,"t":{"3":{"position":[[50,6]]}}}],["abov",{"_index":61,"t":{"5":{"position":[[176,5]]}}}],["activ",{"_index":53,"t":{"3":{"position":[[814,6]]}}}],["alpha",{"_index":76,"t":{"9":{"position":[[41,5]]}}}],["altern",{"_index":31,"t":{"3":{"position":[[364,13]]}}}],["app",{"_index":16,"t":{"3":{"position":[[201,3]]}}}],["ap